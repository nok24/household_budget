# Google Cloud Console で発行した OAuth クライアントID（Web アプリ）
# Step 2 で発行後にこのファイルを .env.local にコピーして埋める
VITE_GOOGLE_CLIENT_ID=

# Google Cloud Console の API キー（Picker API のロード用、必須）
VITE_GOOGLE_API_KEY=

# 家族2名のGmailアドレス（カンマ区切り）。クライアント側のホワイトリスト表示用
# 本丸の認可は OAuth 同意画面の Testing ユーザと Drive のフォルダ共有で行う
VITE_ALLOWED_EMAILS=husband@example.com,wife@example.com
