# wrangler pages dev でローカル実行する際の Secrets / 環境変数。
# 実値は .dev.vars にコピーして埋める (.dev.vars は git 管理外)。

GOOGLE_CLIENT_ID=972177858790-3q7etbmd4829v4mrpvh9s4jbbf11d2pb.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=nok.24.eva.05@gmail.com,mieko.kawamura.mail@gmail.com
ADMIN_EMAILS=nok.24.eva.05@gmail.com
# 256-bit (32 bytes) AES 鍵を base64 エンコードした値。生成例:
#   openssl rand -base64 32
DRIVE_TOKEN_AES_KEY=

# dev モード (HTTP で cookie を発行できるよう Secure / __Host- prefix を無効化)
# 本番では未設定または "false" にする。
IS_DEV=true

# CSRF Origin 検証の追加許可オリジン (カンマ区切り)。
# vite proxy (5173 → 8788) では Origin ヘッダがブラウザ側のオリジン (5173) のまま届くので明示許可する。
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8788

# Drive OAuth コールバック URL の上書き (dev のみ)。
# vite proxy 越しに 5173 で動かすため、Google に投げる redirect_uri を 5173 に揃える。
# Google Cloud Console の Authorized redirect URIs にも同じ URL を登録しておくこと。
# 本番では設定しない (Worker のリクエスト URL から自動算出される)。
OAUTH_REDIRECT_URI=http://localhost:5173/api/admin/drive/callback
